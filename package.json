{
  "name": "ties-obsidian",
  "version": "1.0.1",
  "description": "Ties — Obsidian plugin for typed, meaning-based connections between notes.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "zettelkasten",
    "links",
    "moc",
    "embeddings"
  ],
  "author": "nogipx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nogipx/ties-obsidian.git"
  },
  "bugs": {
    "url": "https://github.com/nogipx/ties-obsidian/issues"
  },
  "homepage": "https://github.com/nogipx/ties-obsidian#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "latest",
    "typescript": "^5.4.5"
  }
}
